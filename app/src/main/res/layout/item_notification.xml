<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="6dp"
    app:cardCornerRadius="20dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        >

        <ImageView
            android:id="@+id/img_notification"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:padding="5dp"
            android:src="@drawable/baseline_home_24"
            android:layout_gravity="center"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_title_notification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ponto 1"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                />

            <TextView
                android:id="@+id/txt_describe_notification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rua Tente a sorte, 1122 Centro, Palmas - PR,  12345-098"
                android:textSize="18sp"
                android:textColor="@color/black"
                />

            <TextView
                android:id="@+id/txt_delay_notification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Atrso: 1min"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                />

        </LinearLayout>

    </LinearLayout>



</androidx.cardview.widget.CardView>